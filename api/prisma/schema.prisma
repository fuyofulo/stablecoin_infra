  metadataJson           Json             @default("{}") @map("metadata_json")
  createdByUserId        String?          @map("created_by_user_id") @db.Uuid
  createdAt              DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization           Organization        @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  sourceTreasuryWallet   TreasuryWallet?  @relation("PaymentRunSourceWallet", fields: [sourceTreasuryWalletId], references: [treasuryWalletId], onDelete: SetNull)
  createdByUser          User?            @relation("PaymentRunCreatedByUser", fields: [createdByUserId], references: [userId], onDelete: SetNull)
