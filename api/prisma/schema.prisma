generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  organizationId   String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("organization_id")
  organizationName String                   @map("organization_name")
  status           String                   @default("active")
  createdAt        DateTime                 @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt        DateTime                 @updatedAt @db.Timestamptz(6) @map("updated_at")
  apiKeys          ApiKey[]
  memberships      OrganizationMembership[]
  sessions         AuthSession[]
  workspaces       Workspace[]
  counterparties   Counterparty[]

  @@map("organizations")
}

model User {
  userId                    String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("user_id")
  email                     String            @unique
  displayName               String            @map("display_name")
  status                    String            @default("active")
  createdAt                 DateTime          @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt                 DateTime          @updatedAt @db.Timestamptz(6) @map("updated_at")
  memberships               OrganizationMembership[]
  sessions                  AuthSession[]
  transferRequestsRequested TransferRequest[] @relation("TransferRequestRequestedByUser")
  transferRequestNotes      TransferRequestNote[]
  exceptionNotes            ExceptionNote[]
  exceptionStatesUpdated    ExceptionState[]
  exceptionStatesAssigned   ExceptionState[] @relation("ExceptionStateAssignee")
  approvalDecisions         ApprovalDecision[]
  apiKeysCreated            ApiKey[]           @relation("ApiKeyCreatedByUser")
  executionRecords          ExecutionRecord[] @relation("ExecutionRecordExecutorUser")
  exportJobs                ExportJob[]
  paymentOrdersCreated      PaymentOrder[]    @relation("PaymentOrderCreatedByUser")
  paymentRequestsCreated    PaymentRequest[]  @relation("PaymentRequestRequestedByUser")
  paymentRunsCreated        PaymentRun[]      @relation("PaymentRunCreatedByUser")

  @@map("users")
}

model OrganizationMembership {
  membershipId   String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("membership_id")
  organizationId String       @db.Uuid @map("organization_id")
  userId         String       @db.Uuid @map("user_id")
  role           String
  status         String       @default("active")
  createdAt      DateTime     @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt      DateTime     @updatedAt @db.Timestamptz(6) @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_memberships")
}

model AuthSession {
  authSessionId  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("auth_session_id")
  sessionToken   String        @unique @map("session_token")
  organizationId String?       @db.Uuid @map("organization_id")
  userId         String        @db.Uuid @map("user_id")
  expiresAt      DateTime      @db.Timestamptz(6) @map("expires_at")
  lastSeenAt     DateTime      @default(now()) @db.Timestamptz(6) @map("last_seen_at")
  createdAt      DateTime      @default(now()) @db.Timestamptz(6) @map("created_at")
  organization   Organization? @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("auth_sessions")
}

model Workspace {
  workspaceId            String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("workspace_id")
  organizationId         String                 @db.Uuid @map("organization_id")
  workspaceName          String                 @map("workspace_name")
  status                 String                 @default("active")
  createdAt              DateTime               @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt              DateTime               @updatedAt @db.Timestamptz(6) @map("updated_at")
  organization           Organization           @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  addresses              WorkspaceAddress[]
  destinations           Destination[]
  transferRequests       TransferRequest[]
  approvalPolicy         ApprovalPolicy?
  approvalDecisions      ApprovalDecision[]
  executionRecords      ExecutionRecord[]
  transferRequestEvents TransferRequestEvent[]
  transferRequestNotes  TransferRequestNote[]
  exceptionNotes       ExceptionNote[]
  exceptionStates      ExceptionState[]
  exportJobs           ExportJob[]
  paymentRuns          PaymentRun[]
  paymentOrders        PaymentOrder[]
  paymentOrderEvents   PaymentOrderEvent[]
  paymentRequests      PaymentRequest[]
  payees               Payee[]
  apiKeys              ApiKey[]

  @@map("workspaces")
}

model ApiKey {
  apiKeyId        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("api_key_id")
  workspaceId     String        @db.Uuid @map("workspace_id")
  organizationId  String        @db.Uuid @map("organization_id")
  createdByUserId String?       @db.Uuid @map("created_by_user_id")
  keyPrefix       String        @map("key_prefix")
  keyHash         String        @unique @map("key_hash")
  label           String
  status          String        @default("active")
  role            String        @default("agent_operator")
  scopes          Json          @default("[]")
  lastUsedAt      DateTime?     @db.Timestamptz(6) @map("last_used_at")
  expiresAt       DateTime?     @db.Timestamptz(6) @map("expires_at")
  revokedAt       DateTime?     @db.Timestamptz(6) @map("revoked_at")
  createdAt       DateTime      @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt       DateTime      @updatedAt @db.Timestamptz(6) @map("updated_at")
  workspace       Workspace     @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  organization    Organization  @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  createdByUser   User?         @relation("ApiKeyCreatedByUser", fields: [createdByUserId], references: [userId], onDelete: SetNull)

  @@unique([workspaceId, label])
  @@index([workspaceId, status, createdAt(sort: Desc)])
  @@index([organizationId, createdAt(sort: Desc)])
  @@map("api_keys")
}

model WorkspaceAddress {
  workspaceAddressId     String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("workspace_address_id")
  workspaceId            String           @db.Uuid @map("workspace_id")
  chain                  String
  address                String
  addressKind            String           @default("wallet") @map("address_kind")
  assetScope             String           @default("usdc") @map("asset_scope")
  usdcAtaAddress         String?          @map("usdc_ata_address")
  isActive               Boolean          @default(true) @map("is_active")
  source                 String           @default("manual")
  sourceRef              String?          @map("source_ref")
  displayName            String?          @map("display_name")
  notes                  String?
  propertiesJson         Json             @default("{}") @map("properties_json")
  createdAt              DateTime         @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt              DateTime         @updatedAt @db.Timestamptz(6) @map("updated_at")
  workspace              Workspace        @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  destinations           Destination[]
  outboundTransferRequests TransferRequest[] @relation("TransferRequestSourceAddress")
  inboundTransferRequests  TransferRequest[] @relation("TransferRequestDestinationAddress")
  sourcePaymentOrders      PaymentOrder[]    @relation("PaymentOrderSourceAddress")
  sourcePaymentRuns        PaymentRun[]      @relation("PaymentRunSourceAddress")

  @@unique([workspaceId, address])
  @@map("workspace_addresses")
}

model Counterparty {
  counterpartyId      String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("counterparty_id")
  organizationId      String        @db.Uuid @map("organization_id")
  displayName         String        @map("display_name")
  category            String
  externalReference   String?       @map("external_reference")
  status              String        @default("active")
  metadataJson        Json          @default("{}") @map("metadata_json")
  createdAt           DateTime      @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt           DateTime      @updatedAt @db.Timestamptz(6) @map("updated_at")
  organization        Organization  @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  destinations        Destination[]
  paymentOrders       PaymentOrder[]
  paymentRequests     PaymentRequest[]

  @@index([organizationId, createdAt(sort: Desc)])
  @@map("counterparties")
}

model Destination {
  destinationId             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("destination_id")
  counterpartyId            String?          @db.Uuid @map("counterparty_id")
  workspaceId               String           @db.Uuid @map("workspace_id")
  linkedWorkspaceAddressId  String?          @db.Uuid @map("linked_workspace_address_id")
  chain                     String
  asset                     String           @default("usdc")
  walletAddress             String           @map("wallet_address")
  tokenAccountAddress       String?          @map("token_account_address")
  destinationType           String           @default("wallet") @map("destination_type")
  trustState                String           @default("unreviewed") @map("trust_state")
  label                     String
  notes                     String?
  isInternal                Boolean          @default(false) @map("is_internal")
  isActive                  Boolean          @default(true) @map("is_active")
  metadataJson              Json             @default("{}") @map("metadata_json")
  createdAt                 DateTime         @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt                 DateTime         @updatedAt @db.Timestamptz(6) @map("updated_at")
  counterparty              Counterparty?    @relation(fields: [counterpartyId], references: [counterpartyId], onDelete: SetNull)
  workspace                 Workspace        @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  linkedWorkspaceAddress    WorkspaceAddress? @relation(fields: [linkedWorkspaceAddressId], references: [workspaceAddressId], onDelete: SetNull)
  transferRequests          TransferRequest[]
  paymentOrders             PaymentOrder[]
  paymentRequests           PaymentRequest[]
  payees                    Payee[]

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([counterpartyId, createdAt(sort: Desc)])
  @@unique([workspaceId, linkedWorkspaceAddressId])
  @@map("destinations")
}

model TransferRequest {
  transferRequestId          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("transfer_request_id")
  workspaceId                String           @db.Uuid @map("workspace_id")
  paymentOrderId             String?          @db.Uuid @map("payment_order_id")
  sourceWorkspaceAddressId   String?          @db.Uuid @map("source_workspace_address_id")
  destinationWorkspaceAddressId String        @db.Uuid @map("destination_workspace_address_id")
  destinationId              String?          @db.Uuid @map("destination_id")
  requestType                String           @map("request_type")
  asset                      String           @default("usdc")
  amountRaw                  BigInt           @map("amount_raw")
  requestedByUserId          String?          @db.Uuid @map("requested_by_user_id")
  reason                     String?
  externalReference          String?          @map("external_reference")
  status                     String           @default("submitted")
  requestedAt                DateTime         @default(now()) @db.Timestamptz(6) @map("requested_at")
  dueAt                      DateTime?        @db.Timestamptz(6) @map("due_at")
  propertiesJson             Json             @default("{}") @map("properties_json")
  createdAt                  DateTime         @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt                  DateTime         @updatedAt @db.Timestamptz(6) @map("updated_at")
  workspace                  Workspace        @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  paymentOrder               PaymentOrder?    @relation(fields: [paymentOrderId], references: [paymentOrderId], onDelete: SetNull)
  sourceWorkspaceAddress     WorkspaceAddress? @relation("TransferRequestSourceAddress", fields: [sourceWorkspaceAddressId], references: [workspaceAddressId], onDelete: SetNull)
  destinationWorkspaceAddress WorkspaceAddress @relation("TransferRequestDestinationAddress", fields: [destinationWorkspaceAddressId], references: [workspaceAddressId], onDelete: Restrict)
  destination                Destination?     @relation(fields: [destinationId], references: [destinationId], onDelete: SetNull)
  requestedByUser            User?            @relation("TransferRequestRequestedByUser", fields: [requestedByUserId], references: [userId], onDelete: SetNull)
  approvalDecisions          ApprovalDecision[]
  executionRecords           ExecutionRecord[]
  events                     TransferRequestEvent[]
  notes                      TransferRequestNote[]

  @@index([workspaceId, status, requestedAt(sort: Desc)])
  @@index([paymentOrderId])
  @@index([destinationWorkspaceAddressId, status, requestedAt(sort: Desc)])
  @@index([destinationId, status, requestedAt(sort: Desc)])
  @@map("transfer_requests")
}

model PaymentOrder {
  paymentOrderId             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("payment_order_id")
  workspaceId                String            @db.Uuid @map("workspace_id")
  paymentRequestId           String?           @unique @db.Uuid @map("payment_request_id")
  paymentRunId               String?           @db.Uuid @map("payment_run_id")
  payeeId                    String?           @db.Uuid @map("payee_id")
  destinationId              String            @db.Uuid @map("destination_id")
  counterpartyId             String?           @db.Uuid @map("counterparty_id")
  sourceWorkspaceAddressId   String?           @db.Uuid @map("source_workspace_address_id")
  amountRaw                  BigInt            @map("amount_raw")
  asset                      String            @default("usdc")
  memo                       String?
  externalReference          String?           @map("external_reference")
  invoiceNumber              String?           @map("invoice_number")
  attachmentUrl              String?           @map("attachment_url")
  dueAt                      DateTime?         @db.Timestamptz(6) @map("due_at")
  state                      String            @default("draft")
  sourceBalanceSnapshotJson  Json              @default("{}") @map("source_balance_snapshot_json")
  metadataJson               Json              @default("{}") @map("metadata_json")
  createdByUserId            String?           @db.Uuid @map("created_by_user_id")
  createdAt                  DateTime          @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt                  DateTime          @updatedAt @db.Timestamptz(6) @map("updated_at")
  workspace                  Workspace         @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  paymentRequest             PaymentRequest?   @relation(fields: [paymentRequestId], references: [paymentRequestId], onDelete: SetNull)
  paymentRun                 PaymentRun?       @relation(fields: [paymentRunId], references: [paymentRunId], onDelete: SetNull)
  payee                      Payee?            @relation(fields: [payeeId], references: [payeeId], onDelete: SetNull)
  destination                Destination       @relation(fields: [destinationId], references: [destinationId], onDelete: Restrict)
  counterparty               Counterparty?     @relation(fields: [counterpartyId], references: [counterpartyId], onDelete: SetNull)
  sourceWorkspaceAddress     WorkspaceAddress? @relation("PaymentOrderSourceAddress", fields: [sourceWorkspaceAddressId], references: [workspaceAddressId], onDelete: SetNull)
  createdByUser              User?             @relation("PaymentOrderCreatedByUser", fields: [createdByUserId], references: [userId], onDelete: SetNull)
  transferRequests           TransferRequest[]
  events                     PaymentOrderEvent[]

  @@index([workspaceId, state, createdAt(sort: Desc)])
  @@index([paymentRequestId])
  @@index([paymentRunId, createdAt(sort: Desc)])
  @@index([payeeId, createdAt(sort: Desc)])
  @@index([destinationId, createdAt(sort: Desc)])
  @@index([sourceWorkspaceAddressId, createdAt(sort: Desc)])
  @@map("payment_orders")
}

model PaymentRequest {
  paymentRequestId  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("payment_request_id")
  workspaceId       String        @db.Uuid @map("workspace_id")
  paymentRunId      String?       @db.Uuid @map("payment_run_id")
  payeeId           String?       @db.Uuid @map("payee_id")
  destinationId     String        @db.Uuid @map("destination_id")
  counterpartyId    String?       @db.Uuid @map("counterparty_id")
  requestedByUserId String?       @db.Uuid @map("requested_by_user_id")
  amountRaw         BigInt        @map("amount_raw")
  asset             String        @default("usdc")
  reason            String
  externalReference String?       @map("external_reference")
  dueAt             DateTime?     @db.Timestamptz(6) @map("due_at")
  state             String        @default("submitted")
  metadataJson      Json          @default("{}") @map("metadata_json")
  createdAt         DateTime      @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt         DateTime      @updatedAt @db.Timestamptz(6) @map("updated_at")
  workspace         Workspace     @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  paymentRun        PaymentRun?   @relation(fields: [paymentRunId], references: [paymentRunId], onDelete: SetNull)
  payee             Payee?        @relation(fields: [payeeId], references: [payeeId], onDelete: SetNull)
  destination       Destination   @relation(fields: [destinationId], references: [destinationId], onDelete: Restrict)
  counterparty      Counterparty? @relation(fields: [counterpartyId], references: [counterpartyId], onDelete: SetNull)
  requestedByUser   User?         @relation("PaymentRequestRequestedByUser", fields: [requestedByUserId], references: [userId], onDelete: SetNull)
  paymentOrder      PaymentOrder?

  @@index([workspaceId, state, createdAt(sort: Desc)])
  @@index([paymentRunId, createdAt(sort: Desc)])
  @@index([payeeId, createdAt(sort: Desc)])
  @@index([destinationId, createdAt(sort: Desc)])
  @@index([counterpartyId, createdAt(sort: Desc)])
  @@unique([workspaceId, destinationId, amountRaw, externalReference])
  @@map("payment_requests")
}

model Payee {
  payeeId              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("payee_id")
  workspaceId          String          @db.Uuid @map("workspace_id")
  defaultDestinationId String?         @db.Uuid @map("default_destination_id")
  name                 String
  externalReference    String?         @map("external_reference")
  status               String          @default("active")
  notes                String?
  metadataJson         Json            @default("{}") @map("metadata_json")
  createdAt            DateTime        @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt            DateTime        @updatedAt @db.Timestamptz(6) @map("updated_at")
  workspace            Workspace       @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  defaultDestination   Destination?    @relation(fields: [defaultDestinationId], references: [destinationId], onDelete: SetNull)
  paymentRequests      PaymentRequest[]
  paymentOrders        PaymentOrder[]

  @@unique([workspaceId, name])
  @@index([workspaceId, status, createdAt(sort: Desc)])
  @@index([defaultDestinationId, createdAt(sort: Desc)])
  @@map("payees")
}

model PaymentRun {
  paymentRunId             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("payment_run_id")
  workspaceId              String            @db.Uuid @map("workspace_id")
  sourceWorkspaceAddressId String?           @db.Uuid @map("source_workspace_address_id")
  runName                  String            @map("run_name")
  inputSource              String            @default("manual") @map("input_source")
  state                    String            @default("draft")
  metadataJson             Json              @default("{}") @map("metadata_json")
  createdByUserId          String?           @db.Uuid @map("created_by_user_id")
  createdAt                DateTime          @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt                DateTime          @updatedAt @db.Timestamptz(6) @map("updated_at")
  workspace                Workspace         @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  sourceWorkspaceAddress   WorkspaceAddress? @relation("PaymentRunSourceAddress", fields: [sourceWorkspaceAddressId], references: [workspaceAddressId], onDelete: SetNull)
  createdByUser            User?             @relation("PaymentRunCreatedByUser", fields: [createdByUserId], references: [userId], onDelete: SetNull)
  paymentRequests          PaymentRequest[]
  paymentOrders            PaymentOrder[]

  @@index([workspaceId, state, createdAt(sort: Desc)])
  @@index([sourceWorkspaceAddressId, createdAt(sort: Desc)])
  @@map("payment_runs")
}

model PaymentOrderEvent {
  paymentOrderEventId String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("payment_order_event_id")
  paymentOrderId      String       @db.Uuid @map("payment_order_id")
  workspaceId         String       @db.Uuid @map("workspace_id")
  eventType           String       @map("event_type")
  actorType           String       @map("actor_type")
  actorId             String?      @map("actor_id")
  beforeState         String?      @map("before_state")
  afterState          String?      @map("after_state")
  linkedTransferRequestId String?  @db.Uuid @map("linked_transfer_request_id")
  linkedExecutionRecordId String?  @db.Uuid @map("linked_execution_record_id")
  linkedSignature     String?      @map("linked_signature")
  payloadJson         Json         @default("{}") @map("payload_json")
  createdAt           DateTime     @default(now()) @db.Timestamptz(6) @map("created_at")
  paymentOrder        PaymentOrder @relation(fields: [paymentOrderId], references: [paymentOrderId], onDelete: Cascade)
  workspace           Workspace    @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)

  @@index([paymentOrderId, createdAt(sort: Asc)])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("payment_order_events")
}

model ExecutionRecord {
  executionRecordId   String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("execution_record_id")
  transferRequestId   String          @db.Uuid @map("transfer_request_id")
  workspaceId         String          @db.Uuid @map("workspace_id")
  submittedSignature  String?         @map("submitted_signature")
  executionSource     String          @default("manual") @map("execution_source")
  executorUserId      String?         @db.Uuid @map("executor_user_id")
  state               String          @default("ready_for_execution")
  submittedAt         DateTime?       @db.Timestamptz(6) @map("submitted_at")
  metadataJson        Json            @default("{}") @map("metadata_json")
  createdAt           DateTime        @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt           DateTime        @updatedAt @db.Timestamptz(6) @map("updated_at")
  transferRequest     TransferRequest @relation(fields: [transferRequestId], references: [transferRequestId], onDelete: Cascade)
  workspace           Workspace       @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  executorUser        User?           @relation("ExecutionRecordExecutorUser", fields: [executorUserId], references: [userId], onDelete: SetNull)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([transferRequestId, createdAt(sort: Desc)])
  @@map("execution_records")
}

model ApprovalPolicy {
  approvalPolicyId    String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("approval_policy_id")
  workspaceId         String     @unique @db.Uuid @map("workspace_id")
  policyName          String     @map("policy_name")
  isActive            Boolean    @default(true) @map("is_active")
  ruleJson            Json       @default("{}") @map("rule_json")
  createdAt           DateTime   @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt           DateTime   @updatedAt @db.Timestamptz(6) @map("updated_at")
  workspace           Workspace  @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  approvalDecisions   ApprovalDecision[]

  @@map("approval_policies")
}

model ApprovalDecision {
  approvalDecisionId  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("approval_decision_id")
  approvalPolicyId    String?         @db.Uuid @map("approval_policy_id")
  transferRequestId   String          @db.Uuid @map("transfer_request_id")
  workspaceId         String          @db.Uuid @map("workspace_id")
  actorUserId         String?         @db.Uuid @map("actor_user_id")
  actorType           String          @default("user") @map("actor_type")
  action              String
  comment             String?
  payloadJson         Json            @default("{}") @map("payload_json")
  createdAt           DateTime        @default(now()) @db.Timestamptz(6) @map("created_at")
  approvalPolicy      ApprovalPolicy? @relation(fields: [approvalPolicyId], references: [approvalPolicyId], onDelete: SetNull)
  transferRequest     TransferRequest @relation(fields: [transferRequestId], references: [transferRequestId], onDelete: Cascade)
  workspace           Workspace       @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  actorUser           User?           @relation(fields: [actorUserId], references: [userId], onDelete: SetNull)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([transferRequestId, createdAt(sort: Asc)])
  @@map("approval_decisions")
}

model TransferRequestEvent {
  transferRequestEventId String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("transfer_request_event_id")
  transferRequestId      String          @db.Uuid @map("transfer_request_id")
  workspaceId            String          @db.Uuid @map("workspace_id")
  eventType              String          @map("event_type")
  actorType              String          @map("actor_type")
  actorId                String?         @map("actor_id")
  eventSource            String          @map("event_source")
  beforeState            String?         @map("before_state")
  afterState             String?         @map("after_state")
  linkedSignature        String?         @map("linked_signature")
  linkedPaymentId        String?         @db.Uuid @map("linked_payment_id")
  linkedTransferIds      Json            @default("[]") @map("linked_transfer_ids")
  payloadJson            Json            @default("{}") @map("payload_json")
  createdAt              DateTime        @default(now()) @db.Timestamptz(6) @map("created_at")
