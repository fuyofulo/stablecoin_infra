generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  organizationId   String                   @id @default(dbgenerated("gen_random_uuid()")) @map("organization_id") @db.Uuid
  organizationName String                   @map("organization_name")
  status           String                   @default("active")
  createdAt        DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  memberships      OrganizationMembership[]
  invites          OrganizationInvite[]
  walletAuthorizations OrganizationWalletAuthorization[]
  sessions         AuthSession[]
  counterparties   Counterparty[]
  treasuryWallets TreasuryWallet[]
  decimalProposals DecimalProposal[]
  destinations Destination[]
  collectionSources CollectionSource[]
  transferRequests TransferRequest[]
  executionRecords ExecutionRecord[]
  transferRequestEvents TransferRequestEvent[]
  transferRequestNotes TransferRequestNote[]
  paymentRuns PaymentRun[]
  paymentOrders PaymentOrder[]
  paymentOrderEvents PaymentOrderEvent[]
  paymentRequests PaymentRequest[]
  collectionRuns CollectionRun[]
  collectionRequests CollectionRequest[]
  collectionEvents CollectionRequestEvent[]

  @@map("organizations")
}

model User {
  userId                     String                   @id @default(dbgenerated("gen_random_uuid()")) @map("user_id") @db.Uuid
  email                      String                   @unique
  displayName                String                   @map("display_name")
  passwordHash               String?                  @map("password_hash")
  googleSubject              String?                  @unique @map("google_subject")
  avatarUrl                  String?                  @map("avatar_url")
  emailVerifiedAt            DateTime?                @map("email_verified_at") @db.Timestamptz(6)
  emailVerificationCodeHash  String?                  @map("email_verification_code_hash")
  emailVerificationExpiresAt DateTime?                @map("email_verification_expires_at") @db.Timestamptz(6)
  status                     String                   @default("active")
  createdAt                  DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  memberships                OrganizationMembership[]
  sessions                   AuthSession[]
  wallets                    PersonalWallet[]
  walletChallenges           WalletChallenge[]
  transferRequestsRequested  TransferRequest[]        @relation("TransferRequestRequestedByUser")
  transferRequestNotes       TransferRequestNote[]
  executionRecords           ExecutionRecord[]        @relation("ExecutionRecordExecutorUser")
  paymentOrdersCreated       PaymentOrder[]           @relation("PaymentOrderCreatedByUser")
  decimalProposalsCreated    DecimalProposal[]        @relation("DecimalProposalCreatedByUser")
  paymentRequestsCreated     PaymentRequest[]         @relation("PaymentRequestRequestedByUser")
  paymentRunsCreated         PaymentRun[]             @relation("PaymentRunCreatedByUser")
  collectionRequestsCreated  CollectionRequest[]      @relation("CollectionRequestCreatedByUser")
  collectionRunsCreated      CollectionRun[]          @relation("CollectionRunCreatedByUser")
  organizationInvitesSent    OrganizationInvite[]     @relation("OrganizationInviteInvitedBy")
  organizationInvitesAccepted OrganizationInvite[]    @relation("OrganizationInviteAcceptedBy")

  @@map("users")
}

/// PersonalWallet — user-owned signing wallet.
/// This wallet belongs to an individual user, not to any organization treasury.
/// It may be authorized to act inside an organization through
/// OrganizationWalletAuthorization, but it never represents org funds by itself.
model PersonalWallet {
  userWalletId     String    @id @default(dbgenerated("gen_random_uuid()")) @map("user_wallet_id") @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  chain            String    @default("solana")
  walletAddress    String    @map("wallet_address")
  walletType       String    @map("wallet_type")
  provider         String?
  providerWalletId String?   @map("provider_wallet_id")
  label            String?
  status           String    @default("active")
  verifiedAt       DateTime? @map("verified_at") @db.Timestamptz(6)
  lastUsedAt       DateTime? @map("last_used_at") @db.Timestamptz(6)
  metadataJson     Json      @default("{}") @map("metadata_json")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User      @relation(fields: [userId], references: [userId], onDelete: Cascade)
  walletAuthorizations OrganizationWalletAuthorization[]

  @@unique([userId, chain, walletAddress])
  @@index([userId, status, createdAt(sort: Desc)])
  @@map("user_wallets")
}

model WalletChallenge {
  walletChallengeId String    @id @default(dbgenerated("gen_random_uuid()")) @map("wallet_challenge_id") @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  chain             String    @default("solana")
  walletAddress     String    @map("wallet_address")
  nonceHash         String    @unique @map("nonce_hash")
  message           String
  expiresAt         DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt        DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user              User      @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, walletAddress, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@map("wallet_challenges")
}

model OrganizationMembership {
  membershipId   String       @id @default(dbgenerated("gen_random_uuid()")) @map("membership_id") @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  role           String
  status         String       @default("active")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization   Organization @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [userId], onDelete: Cascade)
  walletAuthorizations OrganizationWalletAuthorization[]

  @@unique([organizationId, userId])
  @@map("organization_memberships")
}

model OrganizationInvite {
  organizationInviteId String        @id @default(dbgenerated("gen_random_uuid()")) @map("organization_invite_id") @db.Uuid
  organizationId       String        @map("organization_id") @db.Uuid
  invitedEmail         String        @map("invited_email")
  role                 String        @default("member")
  inviteTokenHash      String        @unique @map("invite_token_hash")
  status               String        @default("pending")
  invitedByUserId      String        @map("invited_by_user_id") @db.Uuid
  acceptedByUserId     String?       @map("accepted_by_user_id") @db.Uuid
  expiresAt            DateTime      @map("expires_at") @db.Timestamptz(6)
  acceptedAt           DateTime?     @map("accepted_at") @db.Timestamptz(6)
  revokedAt            DateTime?     @map("revoked_at") @db.Timestamptz(6)
  createdAt            DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization         Organization  @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  invitedByUser        User          @relation("OrganizationInviteInvitedBy", fields: [invitedByUserId], references: [userId], onDelete: Cascade)
  acceptedByUser       User?         @relation("OrganizationInviteAcceptedBy", fields: [acceptedByUserId], references: [userId], onDelete: SetNull)

  @@index([organizationId, status, createdAt(sort: Desc)])
  @@index([invitedEmail, status])
  @@map("organization_invites")
}

model AuthSession {
  authSessionId  String        @id @default(dbgenerated("gen_random_uuid()")) @map("auth_session_id") @db.Uuid
  sessionToken   String        @unique @map("session_token")
  organizationId String?       @map("organization_id") @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  expiresAt      DateTime      @map("expires_at") @db.Timestamptz(6)
  lastSeenAt     DateTime      @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  organization   Organization? @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("auth_sessions")
}

model IdempotencyRecord {
  idempotencyRecordId String   @id @default(dbgenerated("gen_random_uuid()")) @map("idempotency_record_id") @db.Uuid
  key                 String
  requestMethod       String   @map("request_method")
  requestPath         String   @map("request_path")
  requestHash         String   @map("request_hash")
  actorType           String   @map("actor_type")
  actorId             String   @map("actor_id")
  status              String   @default("processing")
  statusCode          Int?     @map("status_code")
  responseBodyJson    Json?    @map("response_body_json")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  expiresAt           DateTime @map("expires_at") @db.Timestamptz(6)

  @@unique([actorType, actorId, requestMethod, requestPath, key])
  @@index([actorType, actorId, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@map("idempotency_records")
}

// TreasuryWallet — wallets the organization owns. The source side of every payment.
// Counterparty addresses (who we pay) live on the Destination row directly and
// are NOT tracked here.
model TreasuryWallet {
  treasuryWalletId         String            @id @default(dbgenerated("gen_random_uuid()")) @map("treasury_wallet_id") @db.Uuid
  organizationId              String            @map("organization_id") @db.Uuid
  chain                    String
  address                  String
  assetScope               String            @default("usdc") @map("asset_scope")
  usdcAtaAddress           String?           @map("usdc_ata_address")
  isActive                 Boolean           @default(true) @map("is_active")
  source                   String            @default("manual")
  sourceRef                String?           @map("source_ref")
  displayName              String?           @map("display_name")
  notes                    String?
  propertiesJson           Json              @default("{}") @map("properties_json")
  createdAt                DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization           Organization         @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  walletAuthorizations OrganizationWalletAuthorization[]
  outboundTransferRequests TransferRequest[] @relation("TransferRequestSourceWallet")
  sourcePaymentOrders      PaymentOrder[]    @relation("PaymentOrderSourceWallet")
  sourcePaymentRuns        PaymentRun[]      @relation("PaymentRunSourceWallet")
  receivingCollections     CollectionRequest[] @relation("CollectionReceivingWallet")
  receivingCollectionRuns  CollectionRun[]     @relation("CollectionRunReceivingWallet")
  decimalProposals         DecimalProposal[]

  @@unique([organizationId, address])
  @@map("treasury_wallets")
}

/// OrganizationWalletAuthorization — explicit bridge between a personal wallet
/// and an organization treasury wallet. This is the control-plane fact that says
/// "this member's personal wallet may act for this org wallet" without making
/// the personal wallet part of the treasury.
model OrganizationWalletAuthorization {
  walletAuthorizationId String                 @id @default(dbgenerated("gen_random_uuid()")) @map("wallet_authorization_id") @db.Uuid
  organizationId        String                 @map("organization_id") @db.Uuid
  treasuryWalletId      String?                @map("treasury_wallet_id") @db.Uuid
  userWalletId          String                 @map("user_wallet_id") @db.Uuid
  membershipId          String                 @map("membership_id") @db.Uuid
  role                  String                 @default("signer")
  status                String                 @default("active")
  scope                 String                 @default("treasury_wallet") @map("scope")
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  revokedAt             DateTime?              @map("revoked_at") @db.Timestamptz(6)
  metadataJson          Json                   @default("{}") @map("metadata_json")
  organization          Organization           @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  treasuryWallet        TreasuryWallet?        @relation(fields: [treasuryWalletId], references: [treasuryWalletId], onDelete: Cascade)
  personalWallet        PersonalWallet         @relation(fields: [userWalletId], references: [userWalletId], onDelete: Cascade)
  membership            OrganizationMembership @relation(fields: [membershipId], references: [membershipId], onDelete: Cascade)

  @@unique([organizationId, treasuryWalletId, userWalletId, role])
  @@index([organizationId, status])
  @@index([userWalletId, status])
  @@index([membershipId, status])
  @@map("organization_wallet_authorizations")
}

model Counterparty {
  counterpartyId    String           @id @default(dbgenerated("gen_random_uuid()")) @map("counterparty_id") @db.Uuid
  organizationId    String           @map("organization_id") @db.Uuid
  displayName       String           @map("display_name")
  category          String
  externalReference String?          @map("external_reference")
  status            String           @default("active")
  metadataJson      Json             @default("{}") @map("metadata_json")
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization      Organization     @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  destinations      Destination[]
  collectionSources CollectionSource[]
  paymentOrders     PaymentOrder[]
  paymentRequests   PaymentRequest[]
  collectionRequests CollectionRequest[]

  @@index([organizationId, createdAt(sort: Desc)])
  @@map("counterparties")
}

// Destination — counterparty endpoint we pay. Stores the external wallet address
// directly. No relation to TreasuryWallet; these are THEIR wallets, not ours.
model Destination {
  destinationId       String            @id @default(dbgenerated("gen_random_uuid()")) @map("destination_id") @db.Uuid
  counterpartyId      String?           @map("counterparty_id") @db.Uuid
  organizationId         String            @map("organization_id") @db.Uuid
  chain               String
  asset               String            @default("usdc")
  walletAddress       String            @map("wallet_address")
  tokenAccountAddress String?           @map("token_account_address")
  destinationType     String            @default("wallet") @map("destination_type")
  trustState          String            @default("unreviewed") @map("trust_state")
  label               String
  notes               String?
  isInternal          Boolean           @default(false) @map("is_internal")
  isActive            Boolean           @default(true) @map("is_active")
  metadataJson        Json              @default("{}") @map("metadata_json")
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  counterparty        Counterparty?     @relation(fields: [counterpartyId], references: [counterpartyId], onDelete: SetNull)
  organization           Organization         @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  transferRequests    TransferRequest[]
  paymentOrders       PaymentOrder[]
  paymentRequests     PaymentRequest[]

  @@unique([organizationId, walletAddress])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([counterpartyId, createdAt(sort: Desc)])
  @@map("destinations")
}

// CollectionSource — counterparty endpoint we receive money from.
// A wallet may be both a Destination and a CollectionSource, but the roles stay
// separate because outbound trust and inbound recognition are different policies.
model CollectionSource {
  collectionSourceId String              @id @default(dbgenerated("gen_random_uuid()")) @map("collection_source_id") @db.Uuid
  counterpartyId     String?             @map("counterparty_id") @db.Uuid
  organizationId        String              @map("organization_id") @db.Uuid
  chain              String              @default("solana")
  asset              String              @default("usdc")
  walletAddress      String              @map("wallet_address")
  tokenAccountAddress String?            @map("token_account_address")
  sourceType         String              @default("payer_wallet") @map("source_type")
  trustState         String              @default("unreviewed") @map("trust_state")
  label              String
  notes              String?
  isActive           Boolean             @default(true) @map("is_active")
  metadataJson       Json                @default("{}") @map("metadata_json")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  counterparty       Counterparty?       @relation(fields: [counterpartyId], references: [counterpartyId], onDelete: SetNull)
  organization           Organization           @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  collectionRequests CollectionRequest[]

  @@unique([organizationId, walletAddress])
  @@unique([organizationId, label])
  @@index([organizationId, trustState, createdAt(sort: Desc)])
  @@index([counterpartyId, createdAt(sort: Desc)])
  @@map("collection_sources")
}

model TransferRequest {
  transferRequestId      String                 @id @default(dbgenerated("gen_random_uuid()")) @map("transfer_request_id") @db.Uuid
  organizationId            String                 @map("organization_id") @db.Uuid
  paymentOrderId         String?                @map("payment_order_id") @db.Uuid
  sourceTreasuryWalletId String?                @map("source_treasury_wallet_id") @db.Uuid
  destinationId          String                 @map("destination_id") @db.Uuid
  requestType            String                 @map("request_type")
  asset                  String                 @default("usdc")
  amountRaw              BigInt                 @map("amount_raw")
  requestedByUserId      String?                @map("requested_by_user_id") @db.Uuid
  reason                 String?
  externalReference      String?                @map("external_reference")
  status                 String                 @default("submitted")
  requestedAt            DateTime               @default(now()) @map("requested_at") @db.Timestamptz(6)
  dueAt                  DateTime?              @map("due_at") @db.Timestamptz(6)
  propertiesJson         Json                   @default("{}") @map("properties_json")
  createdAt              DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization           Organization              @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  paymentOrder           PaymentOrder?          @relation(fields: [paymentOrderId], references: [paymentOrderId], onDelete: SetNull)
  sourceTreasuryWallet   TreasuryWallet?        @relation("TransferRequestSourceWallet", fields: [sourceTreasuryWalletId], references: [treasuryWalletId], onDelete: SetNull)
  destination            Destination            @relation(fields: [destinationId], references: [destinationId], onDelete: Restrict)
  requestedByUser        User?                  @relation("TransferRequestRequestedByUser", fields: [requestedByUserId], references: [userId], onDelete: SetNull)
  executionRecords       ExecutionRecord[]
  events                 TransferRequestEvent[]
  notes                  TransferRequestNote[]
  collectionRequest      CollectionRequest?

  @@index([organizationId, status, requestedAt(sort: Desc)])
  @@index([paymentOrderId])
  @@index([destinationId, status, requestedAt(sort: Desc)])
  @@index([sourceTreasuryWalletId, status, requestedAt(sort: Desc)])
  @@map("transfer_requests")
}

model PaymentOrder {
  paymentOrderId            String              @id @default(dbgenerated("gen_random_uuid()")) @map("payment_order_id") @db.Uuid
  organizationId               String              @map("organization_id") @db.Uuid
  paymentRequestId          String?             @unique @map("payment_request_id") @db.Uuid
  paymentRunId              String?             @map("payment_run_id") @db.Uuid
  destinationId             String              @map("destination_id") @db.Uuid
  counterpartyId            String?             @map("counterparty_id") @db.Uuid
  sourceTreasuryWalletId    String?             @map("source_treasury_wallet_id") @db.Uuid
  amountRaw                 BigInt              @map("amount_raw")
  asset                     String              @default("usdc")
  memo                      String?
  externalReference         String?             @map("external_reference")
  invoiceNumber             String?             @map("invoice_number")
  attachmentUrl             String?             @map("attachment_url")
  dueAt                     DateTime?           @map("due_at") @db.Timestamptz(6)
  state                     String              @default("draft")
  sourceBalanceSnapshotJson Json                @default("{}") @map("source_balance_snapshot_json")
  metadataJson              Json                @default("{}") @map("metadata_json")
  createdByUserId           String?             @map("created_by_user_id") @db.Uuid
  createdAt                 DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization           Organization           @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  paymentRequest            PaymentRequest?     @relation(fields: [paymentRequestId], references: [paymentRequestId], onDelete: SetNull)
  paymentRun                PaymentRun?         @relation(fields: [paymentRunId], references: [paymentRunId], onDelete: SetNull)
  destination               Destination         @relation(fields: [destinationId], references: [destinationId], onDelete: Restrict)
  counterparty              Counterparty?       @relation(fields: [counterpartyId], references: [counterpartyId], onDelete: SetNull)
  sourceTreasuryWallet      TreasuryWallet?     @relation("PaymentOrderSourceWallet", fields: [sourceTreasuryWalletId], references: [treasuryWalletId], onDelete: SetNull)
  createdByUser             User?               @relation("PaymentOrderCreatedByUser", fields: [createdByUserId], references: [userId], onDelete: SetNull)
  transferRequests          TransferRequest[]
  events                    PaymentOrderEvent[]
  proposals                 DecimalProposal[]

  @@index([organizationId, state, createdAt(sort: Desc)])
  @@index([paymentRequestId])
  @@index([paymentRunId, createdAt(sort: Desc)])
  @@index([destinationId, createdAt(sort: Desc)])
  @@index([sourceTreasuryWalletId, createdAt(sort: Desc)])
  @@map("payment_orders")
}

model DecimalProposal {
  decimalProposalId      String          @id @default(dbgenerated("gen_random_uuid()")) @map("decimal_proposal_id") @db.Uuid
  organizationId         String          @map("organization_id") @db.Uuid
  treasuryWalletId       String?         @map("treasury_wallet_id") @db.Uuid
  paymentOrderId         String?         @map("payment_order_id") @db.Uuid
  paymentRunId           String?         @map("payment_run_id") @db.Uuid
  provider               String          @default("squads_v4")
  proposalType           String          @map("proposal_type")
  proposalCategory       String          @map("proposal_category")
  semanticType           String?         @map("semantic_type")
  status                 String          @default("prepared")
  squadsProgramId        String?         @map("squads_program_id")
  squadsMultisigPda      String?         @map("squads_multisig_pda")
  squadsProposalPda      String?         @map("squads_proposal_pda")
  squadsTransactionPda   String?         @map("squads_transaction_pda")
  squadsBatchPda         String?         @map("squads_batch_pda")
  transactionIndex       String?         @map("transaction_index")
  vaultIndex             Int?            @map("vault_index")
  requiredSigner         String?         @map("required_signer")
  creatorPersonalWalletId String?        @map("creator_personal_wallet_id") @db.Uuid
  creatorWalletAddress   String?         @map("creator_wallet_address")
  submittedSignature     String?         @map("submitted_signature")
  executedSignature      String?         @map("executed_signature")
  submittedAt            DateTime?       @map("submitted_at") @db.Timestamptz(6)
  executedAt             DateTime?       @map("executed_at") @db.Timestamptz(6)
  intentJson             Json            @default("{}") @map("intent_json")
  semanticPayloadJson    Json            @default("{}") @map("semantic_payload_json")
  metadataJson           Json            @default("{}") @map("metadata_json")
  createdByUserId        String?         @map("created_by_user_id") @db.Uuid
  createdAt              DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization           Organization    @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  treasuryWallet         TreasuryWallet? @relation(fields: [treasuryWalletId], references: [treasuryWalletId], onDelete: SetNull)
  paymentOrder           PaymentOrder?   @relation(fields: [paymentOrderId], references: [paymentOrderId], onDelete: SetNull)
  paymentRun             PaymentRun?     @relation(fields: [paymentRunId], references: [paymentRunId], onDelete: SetNull)
  createdByUser          User?           @relation("DecimalProposalCreatedByUser", fields: [createdByUserId], references: [userId], onDelete: SetNull)

  @@unique([organizationId, provider, squadsMultisigPda, transactionIndex])
  @@index([organizationId, status, createdAt(sort: Desc)])
  @@index([organizationId, proposalType, createdAt(sort: Desc)])
  @@index([treasuryWalletId, createdAt(sort: Desc)])
  @@index([paymentOrderId, createdAt(sort: Desc)])
  @@index([paymentRunId, createdAt(sort: Desc)])
  @@map("decimal_proposals")
}

model PaymentRequest {
  paymentRequestId  String        @id @default(dbgenerated("gen_random_uuid()")) @map("payment_request_id") @db.Uuid
  organizationId       String        @map("organization_id") @db.Uuid
  paymentRunId      String?       @map("payment_run_id") @db.Uuid
  destinationId     String        @map("destination_id") @db.Uuid
  counterpartyId    String?       @map("counterparty_id") @db.Uuid
  requestedByUserId String?       @map("requested_by_user_id") @db.Uuid
  amountRaw         BigInt        @map("amount_raw")
  asset             String        @default("usdc")
  reason            String
  externalReference String?       @map("external_reference")
  dueAt             DateTime?     @map("due_at") @db.Timestamptz(6)
  state             String        @default("submitted")
  metadataJson      Json          @default("{}") @map("metadata_json")
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization           Organization     @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  paymentRun        PaymentRun?   @relation(fields: [paymentRunId], references: [paymentRunId], onDelete: SetNull)
  destination       Destination   @relation(fields: [destinationId], references: [destinationId], onDelete: Restrict)
  counterparty      Counterparty? @relation(fields: [counterpartyId], references: [counterpartyId], onDelete: SetNull)
  requestedByUser   User?         @relation("PaymentRequestRequestedByUser", fields: [requestedByUserId], references: [userId], onDelete: SetNull)
  paymentOrder      PaymentOrder?

  @@unique([organizationId, destinationId, amountRaw, externalReference])
  @@index([organizationId, state, createdAt(sort: Desc)])
  @@index([paymentRunId, createdAt(sort: Desc)])
  @@index([destinationId, createdAt(sort: Desc)])
  @@index([counterpartyId, createdAt(sort: Desc)])
  @@map("payment_requests")
}

model PaymentRun {
