generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  organizationId   String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("organization_id")
  organizationName String                   @map("organization_name")
  status           String                   @default("active")
  createdAt        DateTime                 @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt        DateTime                 @updatedAt @db.Timestamptz(6) @map("updated_at")
  memberships      OrganizationMembership[]
  sessions         AuthSession[]
  workspaces       Workspace[]

  @@map("organizations")
}

model User {
  userId                    String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("user_id")
  email                     String            @unique
  displayName               String            @map("display_name")
  status                    String            @default("active")
  createdAt                 DateTime          @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt                 DateTime          @updatedAt @db.Timestamptz(6) @map("updated_at")
  memberships               OrganizationMembership[]
  sessions                  AuthSession[]
  transferRequestsRequested TransferRequest[] @relation("TransferRequestRequestedByUser")
  transferRequestNotes      TransferRequestNote[]
  exceptionNotes            ExceptionNote[]
  exceptionStatesUpdated    ExceptionState[]

  @@map("users")
}

model OrganizationMembership {
  membershipId   String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("membership_id")
  organizationId String       @db.Uuid @map("organization_id")
  userId         String       @db.Uuid @map("user_id")
  role           String
  status         String       @default("active")
  createdAt      DateTime     @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt      DateTime     @updatedAt @db.Timestamptz(6) @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_memberships")
}

model AuthSession {
  authSessionId  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("auth_session_id")
  sessionToken   String        @unique @map("session_token")
  organizationId String?       @db.Uuid @map("organization_id")
  userId         String        @db.Uuid @map("user_id")
  expiresAt      DateTime      @db.Timestamptz(6) @map("expires_at")
  lastSeenAt     DateTime      @default(now()) @db.Timestamptz(6) @map("last_seen_at")
  createdAt      DateTime      @default(now()) @db.Timestamptz(6) @map("created_at")
  organization   Organization? @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("auth_sessions")
}

model Workspace {
  workspaceId       String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("workspace_id")
  organizationId    String           @db.Uuid @map("organization_id")
  workspaceName     String           @map("workspace_name")
  status            String           @default("active")
  createdAt         DateTime         @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt         DateTime         @updatedAt @db.Timestamptz(6) @map("updated_at")
  organization      Organization     @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  addresses         WorkspaceAddress[]
  transferRequests  TransferRequest[]
  transferRequestEvents TransferRequestEvent[]
  transferRequestNotes  TransferRequestNote[]
  exceptionNotes       ExceptionNote[]
  exceptionStates      ExceptionState[]

  @@map("workspaces")
}

model WorkspaceAddress {
  workspaceAddressId     String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("workspace_address_id")
  workspaceId            String           @db.Uuid @map("workspace_id")
  chain                  String
  address                String
  addressKind            String           @default("wallet") @map("address_kind")
  assetScope             String           @default("usdc") @map("asset_scope")
  usdcAtaAddress         String?          @map("usdc_ata_address")
  isActive               Boolean          @default(true) @map("is_active")
  source                 String           @default("manual")
  sourceRef              String?          @map("source_ref")
  displayName            String?          @map("display_name")
  notes                  String?
  propertiesJson         Json             @default("{}") @map("properties_json")
  createdAt              DateTime         @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt              DateTime         @updatedAt @db.Timestamptz(6) @map("updated_at")
  workspace              Workspace        @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  outboundTransferRequests TransferRequest[] @relation("TransferRequestSourceAddress")
  inboundTransferRequests  TransferRequest[] @relation("TransferRequestDestinationAddress")

  @@unique([workspaceId, address])
  @@map("workspace_addresses")
}

model TransferRequest {
  transferRequestId          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("transfer_request_id")
  workspaceId                String           @db.Uuid @map("workspace_id")
  sourceWorkspaceAddressId   String?          @db.Uuid @map("source_workspace_address_id")
  destinationWorkspaceAddressId String        @db.Uuid @map("destination_workspace_address_id")
  requestType                String           @map("request_type")
  asset                      String           @default("usdc")
  amountRaw                  BigInt           @map("amount_raw")
  requestedByUserId          String?          @db.Uuid @map("requested_by_user_id")
  reason                     String?
  externalReference          String?          @map("external_reference")
  status                     String           @default("submitted")
  requestedAt                DateTime         @default(now()) @db.Timestamptz(6) @map("requested_at")
  dueAt                      DateTime?        @db.Timestamptz(6) @map("due_at")
  propertiesJson             Json             @default("{}") @map("properties_json")
  createdAt                  DateTime         @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt                  DateTime         @updatedAt @db.Timestamptz(6) @map("updated_at")
  workspace                  Workspace        @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  sourceWorkspaceAddress     WorkspaceAddress? @relation("TransferRequestSourceAddress", fields: [sourceWorkspaceAddressId], references: [workspaceAddressId], onDelete: SetNull)
  destinationWorkspaceAddress WorkspaceAddress @relation("TransferRequestDestinationAddress", fields: [destinationWorkspaceAddressId], references: [workspaceAddressId], onDelete: Restrict)
  requestedByUser            User?            @relation("TransferRequestRequestedByUser", fields: [requestedByUserId], references: [userId], onDelete: SetNull)
  events                     TransferRequestEvent[]
  notes                      TransferRequestNote[]

  @@index([workspaceId, status, requestedAt(sort: Desc)])
  @@index([destinationWorkspaceAddressId, status, requestedAt(sort: Desc)])
  @@map("transfer_requests")
}

model TransferRequestEvent {
  transferRequestEventId String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("transfer_request_event_id")
  transferRequestId      String          @db.Uuid @map("transfer_request_id")
  workspaceId            String          @db.Uuid @map("workspace_id")
  eventType              String          @map("event_type")
  actorType              String          @map("actor_type")
  actorId                String?         @map("actor_id")
  eventSource            String          @map("event_source")
  beforeState            String?         @map("before_state")
  afterState             String?         @map("after_state")
  linkedSignature        String?         @map("linked_signature")
  linkedPaymentId        String?         @db.Uuid @map("linked_payment_id")
  linkedTransferIds      Json            @default("[]") @map("linked_transfer_ids")
  payloadJson            Json            @default("{}") @map("payload_json")
  createdAt              DateTime        @default(now()) @db.Timestamptz(6) @map("created_at")
  transferRequest        TransferRequest @relation(fields: [transferRequestId], references: [transferRequestId], onDelete: Cascade)
  workspace              Workspace       @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)

  @@index([transferRequestId, createdAt(sort: Asc)])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("transfer_request_events")
}

model TransferRequestNote {
  transferRequestNoteId String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("transfer_request_note_id")
  transferRequestId     String          @db.Uuid @map("transfer_request_id")
  workspaceId           String          @db.Uuid @map("workspace_id")
  authorUserId          String?         @db.Uuid @map("author_user_id")
  body                  String
  createdAt             DateTime        @default(now()) @db.Timestamptz(6) @map("created_at")
  transferRequest       TransferRequest @relation(fields: [transferRequestId], references: [transferRequestId], onDelete: Cascade)
  workspace             Workspace       @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  authorUser            User?           @relation(fields: [authorUserId], references: [userId], onDelete: SetNull)

  @@index([transferRequestId, createdAt(sort: Asc)])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("transfer_request_notes")
}

model ExceptionNote {
  exceptionNoteId String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("exception_note_id")
  workspaceId     String    @db.Uuid @map("workspace_id")
  exceptionId     String    @db.Uuid @map("exception_id")
  authorUserId    String?   @db.Uuid @map("author_user_id")
  body            String
  createdAt       DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")
  workspace       Workspace @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  authorUser      User?     @relation(fields: [authorUserId], references: [userId], onDelete: SetNull)

  @@index([exceptionId, createdAt(sort: Asc)])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("exception_notes")
}

model ExceptionState {
  exceptionStateId String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("exception_state_id")
  workspaceId      String    @db.Uuid @map("workspace_id")
  exceptionId      String    @db.Uuid @map("exception_id")
  status           String
  updatedByUserId  String?   @db.Uuid @map("updated_by_user_id")
  createdAt        DateTime  @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt        DateTime  @updatedAt @db.Timestamptz(6) @map("updated_at")
  workspace        Workspace @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  updatedByUser    User?     @relation(fields: [updatedByUserId], references: [userId], onDelete: SetNull)

  @@unique([workspaceId, exceptionId])
  @@index([workspaceId, status, updatedAt(sort: Desc)])
  @@map("exception_states")
}

model AddressLabel {
  addressLabelId String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("address_label_id")
  chain          String
  address        String
  entityName     String   @map("entity_name")
  entityType     String   @map("entity_type")
  labelKind      String   @map("label_kind")
  roleTags       Json     @default("[]") @map("role_tags")
  source         String   @default("manual")
  sourceRef      String?  @map("source_ref")
  confidence     String   @default("seeded")
  isActive       Boolean  @default(true) @map("is_active")
  notes          String?
  createdAt      DateTime @default(now()) @db.Timestamptz(6) @map("created_at")
  updatedAt      DateTime @updatedAt @db.Timestamptz(6) @map("updated_at")

  @@unique([chain, address])
  @@index([chain, address])
  @@map("address_labels")
}
