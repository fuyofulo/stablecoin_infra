model CollectionRequest {
  collectionRequestId       String                   @id @default(dbgenerated("gen_random_uuid()")) @map("collection_request_id") @db.Uuid
  organizationId               String                   @map("organization_id") @db.Uuid
  collectionRunId           String?                  @map("collection_run_id") @db.Uuid
  receivingTreasuryWalletId String                   @map("receiving_treasury_wallet_id") @db.Uuid
  collectionSourceId        String?                  @map("collection_source_id") @db.Uuid
  counterpartyId            String?                  @map("counterparty_id") @db.Uuid
  transferRequestId         String?                  @unique @map("transfer_request_id") @db.Uuid
  payerWalletAddress        String?                  @map("payer_wallet_address")
  payerTokenAccountAddress  String?                  @map("payer_token_account_address")
  amountRaw                 BigInt                   @map("amount_raw")
  asset                     String                   @default("usdc")
  reason                    String
  externalReference         String?                  @map("external_reference")
  dueAt                     DateTime?                @map("due_at") @db.Timestamptz(6)
  state                     String                   @default("open")
  metadataJson              Json                     @default("{}") @map("metadata_json")
  createdByUserId           String?                  @map("created_by_user_id") @db.Uuid
  createdAt                 DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization           Organization                @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  collectionRun             CollectionRun?           @relation(fields: [collectionRunId], references: [collectionRunId], onDelete: SetNull)
  receivingTreasuryWallet   TreasuryWallet           @relation("CollectionReceivingWallet", fields: [receivingTreasuryWalletId], references: [treasuryWalletId], onDelete: Restrict)
  collectionSource          CollectionSource?        @relation(fields: [collectionSourceId], references: [collectionSourceId], onDelete: SetNull)
  counterparty              Counterparty?            @relation(fields: [counterpartyId], references: [counterpartyId], onDelete: SetNull)
  transferRequest           TransferRequest?         @relation(fields: [transferRequestId], references: [transferRequestId], onDelete: SetNull)
  createdByUser             User?                    @relation("CollectionRequestCreatedByUser", fields: [createdByUserId], references: [userId], onDelete: SetNull)
  events                    CollectionRequestEvent[]

  @@unique([organizationId, receivingTreasuryWalletId, amountRaw, externalReference])
  @@index([organizationId, state, createdAt(sort: Desc)])
  @@index([collectionRunId, createdAt(sort: Desc)])
  @@index([receivingTreasuryWalletId, createdAt(sort: Desc)])
  @@index([collectionSourceId, createdAt(sort: Desc)])
  @@index([counterpartyId, createdAt(sort: Desc)])
  @@map("collection_requests")
}

