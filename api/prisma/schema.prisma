generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  organizationId   String                   @id @default(dbgenerated("gen_random_uuid()")) @map("organization_id") @db.Uuid
  organizationName String                   @map("organization_name")
  status           String                   @default("active")
  createdAt        DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  apiKeys          ApiKey[]
  memberships      OrganizationMembership[]
  sessions         AuthSession[]
  workspaces       Workspace[]
  counterparties   Counterparty[]

  @@map("organizations")
}

model User {
  userId                    String                   @id @default(dbgenerated("gen_random_uuid()")) @map("user_id") @db.Uuid
  email                     String                   @unique
  displayName               String                   @map("display_name")
  status                    String                   @default("active")
  createdAt                 DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  memberships               OrganizationMembership[]
  sessions                  AuthSession[]
  transferRequestsRequested TransferRequest[]        @relation("TransferRequestRequestedByUser")
  transferRequestNotes      TransferRequestNote[]
  exceptionNotes            ExceptionNote[]
  exceptionStatesUpdated    ExceptionState[]
  exceptionStatesAssigned   ExceptionState[]         @relation("ExceptionStateAssignee")
  approvalDecisions         ApprovalDecision[]
  apiKeysCreated            ApiKey[]                 @relation("ApiKeyCreatedByUser")
  executionRecords          ExecutionRecord[]        @relation("ExecutionRecordExecutorUser")
  exportJobs                ExportJob[]
  paymentOrdersCreated      PaymentOrder[]           @relation("PaymentOrderCreatedByUser")
  paymentRequestsCreated    PaymentRequest[]         @relation("PaymentRequestRequestedByUser")
  paymentRunsCreated        PaymentRun[]             @relation("PaymentRunCreatedByUser")

  @@map("users")
}

model OrganizationMembership {
  membershipId   String       @id @default(dbgenerated("gen_random_uuid()")) @map("membership_id") @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  role           String
  status         String       @default("active")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization   Organization @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_memberships")
}

model AuthSession {
  authSessionId  String        @id @default(dbgenerated("gen_random_uuid()")) @map("auth_session_id") @db.Uuid
  sessionToken   String        @unique @map("session_token")
  organizationId String?       @map("organization_id") @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  expiresAt      DateTime      @map("expires_at") @db.Timestamptz(6)
  lastSeenAt     DateTime      @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  organization   Organization? @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("auth_sessions")
}

model Workspace {
  workspaceId           String                 @id @default(dbgenerated("gen_random_uuid()")) @map("workspace_id") @db.Uuid
  organizationId        String                 @map("organization_id") @db.Uuid
  workspaceName         String                 @map("workspace_name")
  status                String                 @default("active")
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization          Organization           @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  treasuryWallets       TreasuryWallet[]
  destinations          Destination[]
  transferRequests      TransferRequest[]
  approvalPolicy        ApprovalPolicy?
  approvalDecisions     ApprovalDecision[]
  executionRecords      ExecutionRecord[]
  transferRequestEvents TransferRequestEvent[]
  transferRequestNotes  TransferRequestNote[]
  exceptionNotes        ExceptionNote[]
  exceptionStates       ExceptionState[]
  exportJobs            ExportJob[]
  paymentRuns           PaymentRun[]
  paymentOrders         PaymentOrder[]
  paymentOrderEvents    PaymentOrderEvent[]
  paymentRequests       PaymentRequest[]
  apiKeys               ApiKey[]

  @@map("workspaces")
}

model ApiKey {
  apiKeyId        String       @id @default(dbgenerated("gen_random_uuid()")) @map("api_key_id") @db.Uuid
  workspaceId     String       @map("workspace_id") @db.Uuid
  organizationId  String       @map("organization_id") @db.Uuid
  createdByUserId String?      @map("created_by_user_id") @db.Uuid
  keyPrefix       String       @map("key_prefix")
  keyHash         String       @unique @map("key_hash")
  label           String
  status          String       @default("active")
  role            String       @default("agent_operator")
  scopes          Json         @default("[]")
  lastUsedAt      DateTime?    @map("last_used_at") @db.Timestamptz(6)
  expiresAt       DateTime?    @map("expires_at") @db.Timestamptz(6)
  revokedAt       DateTime?    @map("revoked_at") @db.Timestamptz(6)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspace       Workspace    @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  organization    Organization @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  createdByUser   User?        @relation("ApiKeyCreatedByUser", fields: [createdByUserId], references: [userId], onDelete: SetNull)

  @@unique([workspaceId, label])
  @@index([workspaceId, status, createdAt(sort: Desc)])
  @@index([organizationId, createdAt(sort: Desc)])
  @@map("api_keys")
}

model IdempotencyRecord {
  idempotencyRecordId String   @id @default(dbgenerated("gen_random_uuid()")) @map("idempotency_record_id") @db.Uuid
  key                 String
  requestMethod       String   @map("request_method")
  requestPath         String   @map("request_path")
  requestHash         String   @map("request_hash")
  actorType           String   @map("actor_type")
  actorId             String   @map("actor_id")
  status              String   @default("processing")
  statusCode          Int?     @map("status_code")
  responseBodyJson    Json?    @map("response_body_json")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  expiresAt           DateTime @map("expires_at") @db.Timestamptz(6)

  @@unique([actorType, actorId, requestMethod, requestPath, key])
  @@index([actorType, actorId, createdAt(sort: Desc)])
  @@index([expiresAt])
  @@map("idempotency_records")
}

// TreasuryWallet — wallets the workspace OWNS. The source side of every payment.
// Only these are monitored by the Yellowstone worker.
// Counterparty addresses (who we pay) live on the Destination row directly and
// are NOT tracked here.
model TreasuryWallet {
  treasuryWalletId         String            @id @default(dbgenerated("gen_random_uuid()")) @map("treasury_wallet_id") @db.Uuid
  workspaceId              String            @map("workspace_id") @db.Uuid
  chain                    String
  address                  String
  assetScope               String            @default("usdc") @map("asset_scope")
  usdcAtaAddress           String?           @map("usdc_ata_address")
  isActive                 Boolean           @default(true) @map("is_active")
  source                   String            @default("manual")
  sourceRef                String?           @map("source_ref")
  displayName              String?           @map("display_name")
  notes                    String?
  propertiesJson           Json              @default("{}") @map("properties_json")
  createdAt                DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspace                Workspace         @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  outboundTransferRequests TransferRequest[] @relation("TransferRequestSourceWallet")
  sourcePaymentOrders      PaymentOrder[]    @relation("PaymentOrderSourceWallet")
  sourcePaymentRuns        PaymentRun[]      @relation("PaymentRunSourceWallet")

  @@unique([workspaceId, address])
  @@map("treasury_wallets")
}

model Counterparty {
  counterpartyId    String           @id @default(dbgenerated("gen_random_uuid()")) @map("counterparty_id") @db.Uuid
  organizationId    String           @map("organization_id") @db.Uuid
  displayName       String           @map("display_name")
  category          String
  externalReference String?          @map("external_reference")
  status            String           @default("active")
  metadataJson      Json             @default("{}") @map("metadata_json")
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  organization      Organization     @relation(fields: [organizationId], references: [organizationId], onDelete: Cascade)
  destinations      Destination[]
  paymentOrders     PaymentOrder[]
  paymentRequests   PaymentRequest[]

  @@index([organizationId, createdAt(sort: Desc)])
  @@map("counterparties")
}

// Destination — counterparty endpoint we pay. Stores the external wallet address
// directly. No relation to TreasuryWallet; these are THEIR wallets, not ours.
model Destination {
  destinationId       String            @id @default(dbgenerated("gen_random_uuid()")) @map("destination_id") @db.Uuid
  counterpartyId      String?           @map("counterparty_id") @db.Uuid
  workspaceId         String            @map("workspace_id") @db.Uuid
  chain               String
  asset               String            @default("usdc")
  walletAddress       String            @map("wallet_address")
  tokenAccountAddress String?           @map("token_account_address")
  destinationType     String            @default("wallet") @map("destination_type")
  trustState          String            @default("unreviewed") @map("trust_state")
  label               String
  notes               String?
  isInternal          Boolean           @default(false) @map("is_internal")
  isActive            Boolean           @default(true) @map("is_active")
  metadataJson        Json              @default("{}") @map("metadata_json")
  createdAt           DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  counterparty        Counterparty?     @relation(fields: [counterpartyId], references: [counterpartyId], onDelete: SetNull)
  workspace           Workspace         @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  transferRequests    TransferRequest[]
  paymentOrders       PaymentOrder[]
  paymentRequests     PaymentRequest[]

  @@unique([workspaceId, walletAddress])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([counterpartyId, createdAt(sort: Desc)])
  @@map("destinations")
}

model TransferRequest {
  transferRequestId      String                 @id @default(dbgenerated("gen_random_uuid()")) @map("transfer_request_id") @db.Uuid
  workspaceId            String                 @map("workspace_id") @db.Uuid
  paymentOrderId         String?                @map("payment_order_id") @db.Uuid
  sourceTreasuryWalletId String?                @map("source_treasury_wallet_id") @db.Uuid
  destinationId          String                 @map("destination_id") @db.Uuid
  requestType            String                 @map("request_type")
  asset                  String                 @default("usdc")
  amountRaw              BigInt                 @map("amount_raw")
  requestedByUserId      String?                @map("requested_by_user_id") @db.Uuid
  reason                 String?
  externalReference      String?                @map("external_reference")
  status                 String                 @default("submitted")
  requestedAt            DateTime               @default(now()) @map("requested_at") @db.Timestamptz(6)
  dueAt                  DateTime?              @map("due_at") @db.Timestamptz(6)
  propertiesJson         Json                   @default("{}") @map("properties_json")
  createdAt              DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspace              Workspace              @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  paymentOrder           PaymentOrder?          @relation(fields: [paymentOrderId], references: [paymentOrderId], onDelete: SetNull)
  sourceTreasuryWallet   TreasuryWallet?        @relation("TransferRequestSourceWallet", fields: [sourceTreasuryWalletId], references: [treasuryWalletId], onDelete: SetNull)
  destination            Destination            @relation(fields: [destinationId], references: [destinationId], onDelete: Restrict)
  requestedByUser        User?                  @relation("TransferRequestRequestedByUser", fields: [requestedByUserId], references: [userId], onDelete: SetNull)
  approvalDecisions      ApprovalDecision[]
  executionRecords       ExecutionRecord[]
  events                 TransferRequestEvent[]
  notes                  TransferRequestNote[]

  @@index([workspaceId, status, requestedAt(sort: Desc)])
  @@index([paymentOrderId])
  @@index([destinationId, status, requestedAt(sort: Desc)])
  @@index([sourceTreasuryWalletId, status, requestedAt(sort: Desc)])
  @@map("transfer_requests")
}

model PaymentOrder {
  paymentOrderId            String              @id @default(dbgenerated("gen_random_uuid()")) @map("payment_order_id") @db.Uuid
  workspaceId               String              @map("workspace_id") @db.Uuid
  paymentRequestId          String?             @unique @map("payment_request_id") @db.Uuid
  paymentRunId              String?             @map("payment_run_id") @db.Uuid
  destinationId             String              @map("destination_id") @db.Uuid
  counterpartyId            String?             @map("counterparty_id") @db.Uuid
  sourceTreasuryWalletId    String?             @map("source_treasury_wallet_id") @db.Uuid
  amountRaw                 BigInt              @map("amount_raw")
  asset                     String              @default("usdc")
  memo                      String?
  externalReference         String?             @map("external_reference")
  invoiceNumber             String?             @map("invoice_number")
  attachmentUrl             String?             @map("attachment_url")
  dueAt                     DateTime?           @map("due_at") @db.Timestamptz(6)
  state                     String              @default("draft")
  sourceBalanceSnapshotJson Json                @default("{}") @map("source_balance_snapshot_json")
  metadataJson              Json                @default("{}") @map("metadata_json")
  createdByUserId           String?             @map("created_by_user_id") @db.Uuid
  createdAt                 DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspace                 Workspace           @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  paymentRequest            PaymentRequest?     @relation(fields: [paymentRequestId], references: [paymentRequestId], onDelete: SetNull)
  paymentRun                PaymentRun?         @relation(fields: [paymentRunId], references: [paymentRunId], onDelete: SetNull)
  destination               Destination         @relation(fields: [destinationId], references: [destinationId], onDelete: Restrict)
  counterparty              Counterparty?       @relation(fields: [counterpartyId], references: [counterpartyId], onDelete: SetNull)
  sourceTreasuryWallet      TreasuryWallet?     @relation("PaymentOrderSourceWallet", fields: [sourceTreasuryWalletId], references: [treasuryWalletId], onDelete: SetNull)
  createdByUser             User?               @relation("PaymentOrderCreatedByUser", fields: [createdByUserId], references: [userId], onDelete: SetNull)
  transferRequests          TransferRequest[]
  events                    PaymentOrderEvent[]

  @@index([workspaceId, state, createdAt(sort: Desc)])
  @@index([paymentRequestId])
  @@index([paymentRunId, createdAt(sort: Desc)])
  @@index([destinationId, createdAt(sort: Desc)])
  @@index([sourceTreasuryWalletId, createdAt(sort: Desc)])
  @@map("payment_orders")
}

model PaymentRequest {
  paymentRequestId  String        @id @default(dbgenerated("gen_random_uuid()")) @map("payment_request_id") @db.Uuid
  workspaceId       String        @map("workspace_id") @db.Uuid
  paymentRunId      String?       @map("payment_run_id") @db.Uuid
  destinationId     String        @map("destination_id") @db.Uuid
  counterpartyId    String?       @map("counterparty_id") @db.Uuid
  requestedByUserId String?       @map("requested_by_user_id") @db.Uuid
  amountRaw         BigInt        @map("amount_raw")
  asset             String        @default("usdc")
  reason            String
  externalReference String?       @map("external_reference")
  dueAt             DateTime?     @map("due_at") @db.Timestamptz(6)
  state             String        @default("submitted")
  metadataJson      Json          @default("{}") @map("metadata_json")
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspace         Workspace     @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  paymentRun        PaymentRun?   @relation(fields: [paymentRunId], references: [paymentRunId], onDelete: SetNull)
  destination       Destination   @relation(fields: [destinationId], references: [destinationId], onDelete: Restrict)
  counterparty      Counterparty? @relation(fields: [counterpartyId], references: [counterpartyId], onDelete: SetNull)
  requestedByUser   User?         @relation("PaymentRequestRequestedByUser", fields: [requestedByUserId], references: [userId], onDelete: SetNull)
  paymentOrder      PaymentOrder?

  @@unique([workspaceId, destinationId, amountRaw, externalReference])
  @@index([workspaceId, state, createdAt(sort: Desc)])
  @@index([paymentRunId, createdAt(sort: Desc)])
  @@index([destinationId, createdAt(sort: Desc)])
  @@index([counterpartyId, createdAt(sort: Desc)])
  @@map("payment_requests")
}

model PaymentRun {
  paymentRunId           String           @id @default(dbgenerated("gen_random_uuid()")) @map("payment_run_id") @db.Uuid
  workspaceId            String           @map("workspace_id") @db.Uuid
  sourceTreasuryWalletId String?          @map("source_treasury_wallet_id") @db.Uuid
  runName                String           @map("run_name")
  inputSource            String           @default("manual") @map("input_source")
  state                  String           @default("draft")
  metadataJson           Json             @default("{}") @map("metadata_json")
  createdByUserId        String?          @map("created_by_user_id") @db.Uuid
  createdAt              DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspace              Workspace        @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  sourceTreasuryWallet   TreasuryWallet?  @relation("PaymentRunSourceWallet", fields: [sourceTreasuryWalletId], references: [treasuryWalletId], onDelete: SetNull)
  createdByUser          User?            @relation("PaymentRunCreatedByUser", fields: [createdByUserId], references: [userId], onDelete: SetNull)
  paymentRequests        PaymentRequest[]
  paymentOrders          PaymentOrder[]

  @@index([workspaceId, state, createdAt(sort: Desc)])
  @@index([sourceTreasuryWalletId, createdAt(sort: Desc)])
  @@map("payment_runs")
}

model PaymentOrderEvent {
  paymentOrderEventId     String       @id @default(dbgenerated("gen_random_uuid()")) @map("payment_order_event_id") @db.Uuid
  paymentOrderId          String       @map("payment_order_id") @db.Uuid
  workspaceId             String       @map("workspace_id") @db.Uuid
  eventType               String       @map("event_type")
  actorType               String       @map("actor_type")
  actorId                 String?      @map("actor_id")
  beforeState             String?      @map("before_state")
  afterState              String?      @map("after_state")
  linkedTransferRequestId String?      @map("linked_transfer_request_id") @db.Uuid
  linkedExecutionRecordId String?      @map("linked_execution_record_id") @db.Uuid
  linkedSignature         String?      @map("linked_signature")
  payloadJson             Json         @default("{}") @map("payload_json")
  createdAt               DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  paymentOrder            PaymentOrder @relation(fields: [paymentOrderId], references: [paymentOrderId], onDelete: Cascade)
  workspace               Workspace    @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)

  @@index([paymentOrderId, createdAt(sort: Asc)])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("payment_order_events")
}

model ExecutionRecord {
  executionRecordId  String          @id @default(dbgenerated("gen_random_uuid()")) @map("execution_record_id") @db.Uuid
  transferRequestId  String          @map("transfer_request_id") @db.Uuid
  workspaceId        String          @map("workspace_id") @db.Uuid
  submittedSignature String?         @map("submitted_signature")
  executionSource    String          @default("manual") @map("execution_source")
  executorUserId     String?         @map("executor_user_id") @db.Uuid
  state              String          @default("ready_for_execution")
  submittedAt        DateTime?       @map("submitted_at") @db.Timestamptz(6)
  metadataJson       Json            @default("{}") @map("metadata_json")
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  transferRequest    TransferRequest @relation(fields: [transferRequestId], references: [transferRequestId], onDelete: Cascade)
  workspace          Workspace       @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  executorUser       User?           @relation("ExecutionRecordExecutorUser", fields: [executorUserId], references: [userId], onDelete: SetNull)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([transferRequestId, createdAt(sort: Desc)])
  @@map("execution_records")
}

model ApprovalPolicy {
  approvalPolicyId  String             @id @default(dbgenerated("gen_random_uuid()")) @map("approval_policy_id") @db.Uuid
  workspaceId       String             @unique @map("workspace_id") @db.Uuid
  policyName        String             @map("policy_name")
  isActive          Boolean            @default(true) @map("is_active")
  ruleJson          Json               @default("{}") @map("rule_json")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  workspace         Workspace          @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  approvalDecisions ApprovalDecision[]

  @@map("approval_policies")
}

model ApprovalDecision {
  approvalDecisionId String          @id @default(dbgenerated("gen_random_uuid()")) @map("approval_decision_id") @db.Uuid
  approvalPolicyId   String?         @map("approval_policy_id") @db.Uuid
  transferRequestId  String          @map("transfer_request_id") @db.Uuid
  workspaceId        String          @map("workspace_id") @db.Uuid
  actorUserId        String?         @map("actor_user_id") @db.Uuid
  actorType          String          @default("user") @map("actor_type")
  action             String
  comment            String?
  payloadJson        Json            @default("{}") @map("payload_json")
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  approvalPolicy     ApprovalPolicy? @relation(fields: [approvalPolicyId], references: [approvalPolicyId], onDelete: SetNull)
  transferRequest    TransferRequest @relation(fields: [transferRequestId], references: [transferRequestId], onDelete: Cascade)
  workspace          Workspace       @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)
  actorUser          User?           @relation(fields: [actorUserId], references: [userId], onDelete: SetNull)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([transferRequestId, createdAt(sort: Asc)])
  @@map("approval_decisions")
}

model TransferRequestEvent {
  transferRequestEventId String          @id @default(dbgenerated("gen_random_uuid()")) @map("transfer_request_event_id") @db.Uuid
  transferRequestId      String          @map("transfer_request_id") @db.Uuid
  workspaceId            String          @map("workspace_id") @db.Uuid
  eventType              String          @map("event_type")
  actorType              String          @map("actor_type")
  actorId                String?         @map("actor_id")
  eventSource            String          @map("event_source")
  beforeState            String?         @map("before_state")
  afterState             String?         @map("after_state")
  linkedSignature        String?         @map("linked_signature")
  linkedPaymentId        String?         @map("linked_payment_id") @db.Uuid
  linkedTransferIds      Json            @default("[]") @map("linked_transfer_ids")
  payloadJson            Json            @default("{}") @map("payload_json")
  createdAt              DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  transferRequest        TransferRequest @relation(fields: [transferRequestId], references: [transferRequestId], onDelete: Cascade)
  workspace              Workspace       @relation(fields: [workspaceId], references: [workspaceId], onDelete: Cascade)

  @@index([transferRequestId, createdAt(sort: Asc)])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("transfer_request_events")
}

model TransferRequestNote {
  transferRequestNoteId String          @id @default(dbgenerated("gen_random_uuid()")) @map("transfer_request_note_id") @db.Uuid
  transferRequestId     String          @map("transfer_request_id") @db.Uuid
  workspaceId           String          @map("workspace_id") @db.Uuid
  authorUserId          String?         @map("author_user_id") @db.Uuid
  body                  String
